//program 7 
//print pramid shape 

#include <iostream>
using namespace std;

int main (){
    int n;
    cin >> n;

    for (int i = 1; i <= n; i++){
        
        // spaces
        for (int j = n - i; j >= 1; j--){
            cout << " ";
        }

        // stars
        for (int k = 1; k <= i; k++){
            cout << "* ";
        }

        cout << "\n";
    }

    return 0;
}
